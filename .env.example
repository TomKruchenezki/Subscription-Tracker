# ============================================================
# Subscription Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.
# ============================================================

# === Gmail OAuth ===
# Create a GCP project at console.cloud.google.com
# Enable the Gmail API, then create OAuth 2.0 credentials (type: Desktop app).
# Download the credentials JSON. Do NOT commit that file — set the values here.
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
# FastAPI handles the OAuth callback at /api/oauth/callback (do not change).
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/oauth/callback

# === Token Storage ===
# "keyring" — stores the encrypted refresh token in your OS keyring (RECOMMENDED for all
#             personal use — the key never touches disk).
# "file"    — AES-256 encrypted local file. Only use for CI/headless environments.
#             WARNING: if TOKEN_ENCRYPTION_KEY is also in this .env file, an attacker who
#             reads .env gets both the key and the encrypted token. Not a real security
#             improvement over plaintext in that scenario. Use keyring for personal use.
TOKEN_STORAGE_BACKEND=keyring
# Required only when TOKEN_STORAGE_BACKEND=file (CI/headless use).
# Must be at least 32 characters. Set this via an environment variable injected by your
# CI system — do NOT hardcode it in .env on a personal machine.
# TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_string_at_least_32_chars

# === Database ===
# Path to the local SQLite database file. Directory must exist.
DB_PATH=data/subscriptions.db

# === App Mode ===
# Set to "true" to use synthetic mock data instead of hitting the Gmail API.
# Always start here in development — no Gmail account needed.
USE_MOCK=true

# === API Server ===
API_HOST=127.0.0.1
API_PORT=8000

# === Logging ===
# Options: DEBUG | INFO | WARNING | ERROR
# WARNING: DEBUG may log email subject lines. Do not use in production.
LOG_LEVEL=INFO

# === Subscription Detection Thresholds ===
# Confidence score >= AUTO_DETECT_THRESHOLD → subscription auto-added.
AUTO_DETECT_THRESHOLD=0.70
# Confidence score >= REVIEW_THRESHOLD (and < AUTO_DETECT_THRESHOLD) → flagged for review.
# Below REVIEW_THRESHOLD → ignored entirely.
REVIEW_THRESHOLD=0.40
