# === Secrets and credentials — NEVER commit these ===
.env
.env.local
.env.*.local
credentials.json
token.json
client_secret*.json
*oauth*.json
encrypted_token
*.token
*.key

# Block all JSON by default to catch stray credential files,
# but explicitly allow mock fixtures and agent definitions below.
*.json
!data/mock/*.json
!.claude/agents/*.json

